#!/bin/sh
set -u

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"

printf '== FlyAI / Feizhu ==\n'
if [ -x "$ROOT/toolkit/fz/fz-status" ]; then
  "$ROOT/toolkit/fz/fz-status" || true
else
  printf 'toolkit/fz/fz-status missing\n'
fi

printf '\n== Xiaohongshu ==\n'
if [ -x "$ROOT/toolkit/xhs/xhs-mcp-status" ]; then
  "$ROOT/toolkit/xhs/xhs-mcp-status" || true
else
  printf 'toolkit/xhs/xhs-mcp-status missing\n'
fi

printf '\n== Airbnb ==\n'
if [ -x "$ROOT/toolkit/airbnb/airbnb-mcp-list" ]; then
  "$ROOT/toolkit/airbnb/airbnb-mcp-list" || true
else
  printf 'toolkit/airbnb/airbnb-mcp-list missing\n'
fi

printf '\n== Booking.com ==\n'
if [ -x "$ROOT/toolkit/booking/booking-mcp-list" ]; then
  "$ROOT/toolkit/booking/booking-mcp-list" || true
else
  printf 'toolkit/booking/booking-mcp-list missing\n'
fi

printf '\n== Google Maps / Monitoring ==\n'
if [ -x "$ROOT/toolkit/google/google-usage" ]; then
  "$ROOT/toolkit/google/google-usage" || true
else
  printf 'toolkit/google/google-usage missing\n'
fi
