#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  ./toolkit/booking/booking-search destination="Tbilisi, Georgia" checkIn=2026-09-25 checkOut=2026-10-07 adults=2 rooms=1

Common args passed to booking_search:
  destination=...
  checkIn=YYYY-MM-DD
  checkOut=YYYY-MM-DD
  adults=1
  children=0
  rooms=1
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]]; then
  usage
  exit 0
fi

exec "${SCRIPT_DIR}/booking-mcp-env" call booking_search "$@" --timeout "${BOOKING_TIMEOUT:-180000}"
