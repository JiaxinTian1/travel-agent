#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  ./toolkit/booking/booking-reviews propertyUrl="<propertyId-or-url-from-booking-search>"

Common args passed to booking_get_reviews:
  propertyUrl=...
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]]; then
  usage
  exit 0
fi

exec "${SCRIPT_DIR}/booking-mcp-env" call booking_get_reviews "$@" --timeout "${BOOKING_TIMEOUT:-180000}"
