#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
BIN="$SCRIPT_DIR/xhs-mcp/xiaohongshu-mcp-linux-amd64"
PIDS="$(pgrep -f "$BIN" || true)"

if [ -z "$PIDS" ]; then
  printf 'No xiaohongshu MCP service is running.
'
  exit 0
fi

printf 'Stopping xiaohongshu MCP service: %s
' "$PIDS"
kill $PIDS
