#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
QR_DIR="$SCRIPT_DIR/qr"
MCPORTER="${MCPORTER:-mcporter}"
mkdir -p "$QR_DIR"
rm -f "$QR_DIR"/mcp-image-*.png

"$MCPORTER" call xiaohongshu-xpz.get_login_qrcode --save-images "$QR_DIR" --output text

LATEST="$(ls -t "$QR_DIR"/mcp-image-*.png 2>/dev/null | head -n 1 || true)"
if [ -z "$LATEST" ]; then
  printf '
No QR image was saved. Check whether xiaohongshu-xpz MCP service is running.
' >&2
  exit 1
fi

WIN_PATH="$(printf '%s' "$LATEST" | sed 's#/#\#g')"
printf '
QR saved:
%s

' "$LATEST"
printf 'Open from Windows Explorer:
\\wsl$\Ubuntu%s

' "$WIN_PATH"
printf 'Waiting for login confirmation...
'

i=0
while [ "$i" -lt 80 ]; do
  OUT="$("$MCPORTER" call xiaohongshu-xpz.check_login_status --output text 2>&1 || true)"
  printf '%s
' "$OUT" | grep -q '已登录' && {
    printf '
Login confirmed:
%s
' "$OUT"
    exit 0
  }
  printf '.'
  i=$((i + 1))
  sleep 3
done

printf '
Login was not confirmed within 4 minutes. Generate a fresh QR and try again.
' >&2
exit 1
