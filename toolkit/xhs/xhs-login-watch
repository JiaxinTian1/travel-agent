#!/bin/sh
set -eu

BASE="/home/snowbolwer/travel-agent/toolkit/xhs"
QR_DIR="$BASE/qr"
MCPORTER="/home/snowbolwer/.local/bin/mcporter"
mkdir -p "$QR_DIR"
rm -f "$QR_DIR"/mcp-image-*.png

"$MCPORTER" call xiaohongshu-xpz.get_login_qrcode --save-images "$QR_DIR" --output text

LATEST="$(ls -t "$QR_DIR"/mcp-image-*.png 2>/dev/null | head -n 1 || true)"
if [ -z "$LATEST" ]; then
  printf '\nNo QR image was saved. Check whether xiaohongshu-xpz MCP service is running.\n' >&2
  exit 1
fi

WIN_PATH="$(printf '%s' "$LATEST" | sed 's#/#\\#g')"
printf '\nQR saved:\n%s\n\n' "$LATEST"
printf 'Open from Windows Explorer:\n\\\\wsl$\\Ubuntu%s\n\n' "$WIN_PATH"
printf 'Waiting for login confirmation...\n'

i=0
while [ "$i" -lt 80 ]; do
  OUT="$("$MCPORTER" call xiaohongshu-xpz.check_login_status --output text 2>&1 || true)"
  printf '%s\n' "$OUT" | grep -q '已登录' && {
    printf '\nLogin confirmed:\n%s\n' "$OUT"
    exit 0
  }
  printf '.'
  i=$((i + 1))
  sleep 3
done

printf '\nLogin was not confirmed within 4 minutes. Generate a fresh QR and try again.\n' >&2
exit 1
