#!/bin/sh
set -u

MCPORTER="${MCPORTER:-mcporter}"

printf '== xiaohongshu MCP port ==
'
ss -ltnp 2>/dev/null | grep ':18060' || printf '18060 is not listening
'

printf '
== xiaohongshu MCP processes ==
'
ps -ef | grep '[x]iaohongshu-mcp' || printf 'no xiaohongshu-mcp process
'

printf '
== login status ==
'
"$MCPORTER" call xiaohongshu-xpz.check_login_status --timeout 30000 --output text || true

printf '
== search smoke test ==
'
"$MCPORTER" call xiaohongshu-xpz.search_feeds --timeout 60000 --args '{"keyword":"成都亲子游"}' --output text   | sed -n '1,80p'
