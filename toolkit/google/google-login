#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
APP_ENV="${ROOT}/app/.env"
GCLOUD_BIN="${GCLOUD_BIN:-}"

if [[ -z "$GCLOUD_BIN" ]]; then
  for candidate in "$HOME/.local/bin/gcloud" "$HOME/.local/google-cloud-sdk/bin/gcloud" gcloud; do
    if command -v "$candidate" >/dev/null 2>&1; then
      GCLOUD_BIN="$(command -v "$candidate")"
      break
    elif [[ -x "$candidate" ]]; then
      GCLOUD_BIN="$candidate"
      break
    fi
  done
fi

if [[ -z "$GCLOUD_BIN" ]]; then
  cat <<EOF
gcloud is not installed.

Run:
  ./install.sh --install-gcloud
EOF
  exit 1
fi

echo "Using gcloud: $GCLOUD_BIN"
echo
cat <<'EOF'
This login is for Google Cloud Monitoring usage checks.

Required IAM on the Google Cloud project:
  Monitoring Viewer

This script uses Application Default Credentials and does not create a
service-account JSON key.
EOF

echo
"$GCLOUD_BIN" auth application-default login --no-launch-browser

echo
echo "Checking ADC token..."
"$GCLOUD_BIN" auth application-default print-access-token >/dev/null
echo "ADC token OK."

project_id=""
if [[ -f "$APP_ENV" ]]; then
  project_id="$(grep -E '^GOOGLE_CLOUD_PROJECT_ID=' "$APP_ENV" | tail -n 1 | cut -d= -f2- || true)"
fi

if [[ -n "$project_id" ]]; then
  echo "Configured GOOGLE_CLOUD_PROJECT_ID=$project_id"
else
  cat <<EOF

Next: set your project id in app/.env:

  GOOGLE_USAGE_SOURCE=monitoring
  GOOGLE_CLOUD_PROJECT_ID=your-project-id

Then test:

  ./toolkit/google/google-usage
EOF
fi
