# Optional Airbnb MCP wrapper settings.
#
# Default uses npx from PATH. In WSL, prefer a Linux Node.js/npm install.
# NPX=npx
#
# Bypass robots.txt by default so Airbnb search calls return live data.
# Set to false if you want strict robots.txt compliance.
# AIRBNB_IGNORE_ROBOTS=true
#
# Disable Photon/Nominatim geocoding. Not recommended for international searches.
# DISABLE_GEOCODING=false
