#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
FLYAI="$SCRIPT_DIR/flyai-env"

printf '== FlyAI CLI ==
'
command -v "${FLYAI_BIN:-flyai}" || true

printf '
== FlyAI env ==
'
if grep -q '^FLYAI_API_KEY=' "$SCRIPT_DIR/.env"; then
  printf 'FLYAI_API_KEY is configured in toolkit/fz/.env
'
else
  printf 'FLYAI_API_KEY is missing in toolkit/fz/.env
' >&2
  exit 1
fi

printf '
== flight smoke test ==
'
"$FLYAI" search-flight --origin "上海" --destination "北京" --dep-date 2026-07-01 --sort-type 3
