# App-level environment config.
# Copy to app/.env and fill only the providers you want to enable.

# LLM agent config. These are the usual three required values.
# Without OPENAI_API_KEY, model-driven agent calls are disabled and local fallback is used.
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://tokenrai.com/v1
# Use openai-responses for official OpenAI Responses API.
# Use openai-chat-completions for OpenAI-compatible /chat/completions proxies.
OPENAI_API_MODE=openai-chat-completions

# Booking toolkit.
# Anonymous hotel search does not require Booking login.
NPX=npx
MCPORTER=mcporter
BOOKING_TIMEOUT=180000

# Airbnb toolkit.
# Set AIRBNB_IGNORE_ROBOTS=false if you want strict robots.txt compliance.
AIRBNB_TIMEOUT=120000
AIRBNB_IGNORE_ROBOTS=true
DISABLE_GEOCODING=false

# Xiaohongshu toolkit.
# Requires xhs MCP service/login to be set up separately.
XHS_TIMEOUT=60000
XHS_MCP_PORT=18060

# FlyAI / Feizhu toolkit.
# Optional; FlyAI may work without a key, but quota/result quality can depend on it.
FLYAI_API_KEY=
FLYAI_BIN=flyai
FZ_TIMEOUT=120000

# OpenRouteService toolkit.
# Optional. Without this, route_places returns a straight-line/local summary fallback.
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
ORS_PROFILE=driving-car

# AMap / Gaode map toolkit.
# AMAP_MAPS_API_KEY enables backend route planning through Gaode Web Service API.
# AMAP_JS_API_KEY enables the web UI map background through Gaode JS API.
# If they are the same key, you can fill only AMAP_MAPS_API_KEY.
AMAP_MAPS_API_KEY=
AMAP_JS_API_KEY=
AMAP_SECURITY_JS_CODE=

# Mapbox toolkit.
# Recommended primary provider for global map backgrounds and routing.
# Use a public token with URL restrictions for browser map rendering.
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
MAPBOX_PROFILE=driving
