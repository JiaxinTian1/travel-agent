# App-level environment config.
# Copy to app/.env and fill only the providers you want to enable.

# LLM agent config. These are the usual three required values.
# Without OPENAI_API_KEY, model-driven agent calls are disabled and local fallback is used.
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://tokenrai.com/v1
# Use openai-responses for official OpenAI Responses API.
# Use openai-chat-completions for OpenAI-compatible /chat/completions proxies.
OPENAI_API_MODE=openai-chat-completions

# Booking toolkit.
# Anonymous hotel search does not require Booking login.
NPX=npx
MCPORTER=mcporter
BOOKING_TIMEOUT=180000

# Airbnb toolkit.
# Set AIRBNB_IGNORE_ROBOTS=false if you want strict robots.txt compliance.
AIRBNB_TIMEOUT=120000
AIRBNB_IGNORE_ROBOTS=true
DISABLE_GEOCODING=false

# Xiaohongshu toolkit.
# Requires xhs MCP service/login to be set up separately.
XHS_TIMEOUT=60000
XHS_MCP_PORT=18060

# FlyAI / Feizhu toolkit.
# Optional; FlyAI may work without a key, but quota/result quality can depend on it.
FLYAI_API_KEY=
FLYAI_BIN=flyai
FZ_TIMEOUT=120000

# Google Maps Platform toolkit.
# Enables global Places, Geocoding, and Routes for backend recommendations/routing.
# The monthly limits are local guards; set lower values than your billing quota.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DISABLED=false
GOOGLE_MONTHLY_LIMIT_PLACES=5000
GOOGLE_MONTHLY_LIMIT_DETAILS=5000
GOOGLE_MONTHLY_LIMIT_GEOCODE=10000
GOOGLE_MONTHLY_LIMIT_ROUTES=10000
# local: use workspace/app-state/google-usage.json only.
# auto: use Cloud Monitoring when configured, otherwise local.
# monitoring: require Cloud Monitoring before each Google API request.
GOOGLE_USAGE_SOURCE=local
# Required when GOOGLE_USAGE_SOURCE=monitoring/auto.
GOOGLE_CLOUD_PROJECT_ID=
# Auth options for Cloud Monitoring:
# 1) service account JSON with Monitoring Viewer permission:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/service-account.json
# 2) or run: gcloud auth application-default login
# 3) or use short-lived impersonation without JSON keys:
# GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=travel-agent-monitoring@your-project.iam.gserviceaccount.com
# Optional: restrict Monitoring counts to one API key credential id.
GOOGLE_MONITORING_CREDENTIAL_ID=
# Optional service overrides, comma-separated.
GOOGLE_MONITORING_SERVICES_PLACES=places.googleapis.com
GOOGLE_MONITORING_SERVICES_DETAILS=places.googleapis.com
GOOGLE_MONITORING_SERVICES_GEOCODE=geocoding-backend.googleapis.com,geocoding.googleapis.com
GOOGLE_MONITORING_SERVICES_ROUTES=routes.googleapis.com
# Optional method overrides, comma-separated. Defaults are set in app/toolkit/google.js.
GOOGLE_MONITORING_METHODS_PLACES=google.maps.places.v1.Places.SearchText,google.maps.places.v1.Places.SearchNearby
GOOGLE_MONITORING_METHODS_DETAILS=google.maps.places.v1.Places.GetPlace
GOOGLE_MONITORING_METHODS_ROUTES=google.maps.routing.v2.Routes.ComputeRoutes

# AMap / Gaode map toolkit.
# AMAP_MAPS_API_KEY enables backend route planning through Gaode Web Service API.
# AMAP_JS_API_KEY enables the web UI map background through Gaode JS API.
# If they are the same key, you can fill only AMAP_MAPS_API_KEY.
AMAP_MAPS_API_KEY=
AMAP_JS_API_KEY=
AMAP_SECURITY_JS_CODE=

# Mapbox toolkit.
# Recommended primary provider for global map backgrounds and routing.
# Use a public token with URL restrictions for browser map rendering.
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
MAPBOX_PROFILE=driving
