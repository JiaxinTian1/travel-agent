{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-agent.local/schema/board-state.schema.json",
  "title": "Travel Planner Board State",
  "type": "object",
  "required": ["schemaVersion", "researcher", "planners", "openPlannerIds"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "activeTab": { "type": "string" },
    "researcher": { "$ref": "#/$defs/researcherState" },
    "planners": {
      "type": "array",
      "items": { "$ref": "#/$defs/plannerState" }
    },
    "openPlannerIds": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "researcherState": {
      "type": "object",
      "required": ["setIndex", "sets"],
      "additionalProperties": true,
      "properties": {
        "setIndex": { "type": "integer", "minimum": 0 },
        "sets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/researcherSet" }
        }
      }
    },
    "researcherSet": {
      "type": "object",
      "required": ["seed", "candidates"],
      "additionalProperties": true,
      "properties": {
        "seed": { "type": "string", "minLength": 1 },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/destinationCandidate" }
        }
      }
    },
    "destinationCandidate": {
      "type": "object",
      "required": ["id", "name", "score", "rank", "seed", "detail", "scores"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "plannerId": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "score": { "type": "number" },
        "rank": { "type": "integer", "minimum": 1 },
        "seed": { "type": "string", "minLength": 1 },
        "detail": { "$ref": "#/$defs/destinationDetail" },
        "scores": { "$ref": "#/$defs/destinationScores" }
      }
    },
    "destinationDetail": {
      "type": "object",
      "required": ["nature", "culture", "weather", "reviews", "flights", "cost", "premium", "duration"],
      "additionalProperties": true,
      "properties": {
        "nature": { "type": "string" },
        "culture": { "type": "string" },
        "weather": { "type": "string" },
        "reviews": { "type": "string" },
        "flights": { "type": "string" },
        "cost": { "type": "string" },
        "premium": { "type": "string" },
        "duration": { "type": "string" }
      }
    },
    "destinationScores": {
      "type": "object",
      "required": ["nature", "culture", "weather", "reviews", "flights", "cost", "premium", "duration"],
      "additionalProperties": false,
      "properties": {
        "nature": { "$ref": "#/$defs/score" },
        "culture": { "$ref": "#/$defs/score" },
        "weather": { "$ref": "#/$defs/score" },
        "reviews": { "$ref": "#/$defs/score" },
        "flights": { "$ref": "#/$defs/score" },
        "cost": { "$ref": "#/$defs/score" },
        "premium": { "$ref": "#/$defs/score" },
        "duration": { "$ref": "#/$defs/score" }
      }
    },
    "score": { "type": "number", "minimum": 0, "maximum": 10 },
    "plannerState": {
      "type": "object",
      "required": ["id", "destinationId", "researchSeed", "title", "destinationName", "candidates", "staging", "itinerary"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "destinationId": { "type": "string", "minLength": 1 },
        "researchSeed": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "destinationName": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "candidates": {
          "type": "object",
          "required": ["restaurants", "hotels", "attractions", "flights"],
          "additionalProperties": false,
          "properties": {
            "restaurants": { "type": "array", "items": { "$ref": "#/$defs/placeItem" } },
            "hotels": { "type": "array", "items": { "$ref": "#/$defs/placeItem" } },
            "attractions": { "type": "array", "items": { "$ref": "#/$defs/placeItem" } },
            "flights": { "type": "array", "items": { "$ref": "#/$defs/placeItem" } }
          }
        },
        "staging": {
          "type": "array",
          "items": { "$ref": "#/$defs/scheduledItem" }
        },
        "itinerary": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/scheduledItem" }
        }
      }
    },
    "placeItem": {
      "type": "object",
      "required": ["id", "name", "type", "lat", "lng"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["restaurant", "hotel", "attraction", "flight"] },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "note": { "type": "string" },
        "source": { "type": "string" },
        "confidence": { "type": "string" }
      }
    },
    "scheduledItem": {
      "allOf": [
        { "$ref": "#/$defs/placeItem" },
        {
          "type": "object",
          "required": ["instanceId"],
          "properties": {
            "instanceId": { "type": "string", "minLength": 1 },
            "itemId": { "type": "string" }
          }
        }
      ]
    }
  }
}
